{
  "name": "opencut-panel",
  "version": "1.33.1",
  "private": true,
  "description": "OpenCut CEP Panel for Adobe Premiere Pro",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint client/main.js && npm run lint:premiere",
    "lint:premiere": "cd ../com.opencut.uxp && eslint main.js",
    "test": "vitest run --config vitest.config.mjs",
    "audit:check": "node scripts/check-advisories.mjs",
    "audit:check:win": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%INIT_CWD%\\scripts\\panel-node-gate.ps1\" audit:check",
    "audit:esbuild": "node scripts/check-esbuild-pin.mjs",
    "audit:esbuild:win": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%INIT_CWD%\\scripts\\panel-node-gate.ps1\" audit:esbuild",
    "build:verify": "node scripts/verify-build.mjs",
    "build:verify:win": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%INIT_CWD%\\scripts\\panel-node-gate.ps1\" build:verify"
  },
  "devDependencies": {
    "@adobe/eslint-plugin-premierepro": "26.3.0",
    "@adobe/premierepro": "26.3.0",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "terser": "^5.47.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "js-yaml": "^4.2.0"
  }
}
