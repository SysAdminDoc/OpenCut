<Page x:Class="OpenCut.Installer.Pages.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="40,16,40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Installation Options" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   FontFamily="{DynamicResource UIFont}" Margin="0,0,0,12" />

        <!-- Options ScrollViewer -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <!-- Install Location -->
                <TextBlock Text="Install Location" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathBox" Grid.Column="0"
                             Text="C:\Program Files\OpenCut" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Content="Browse..."
                            Style="{StaticResource SecondaryButton}"
                            Click="Browse_Click" Padding="12,8" />
                </Grid>
                <TextBlock x:Name="DiskSpace" Text="" FontSize="11"
                           Foreground="{DynamicResource Overlay0}" Margin="0,2,0,12" />

                <!-- Separator -->
                <Rectangle Height="1" Fill="{DynamicResource Surface1}" Margin="0,4,0,12" />

                <!-- Adobe Integration -->
                <TextBlock Text="Adobe Integration" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6" />
                <CheckBox x:Name="CepCheck" Content="Install Premiere Pro CEP extension"
                          IsChecked="True" Margin="0,0,0,2" />
                <CheckBox x:Name="DebugModeCheck" Content="Enable PlayerDebugMode (required for CEP)"
                          IsChecked="True" Margin="16,0,0,0" />

                <!-- Separator -->
                <Rectangle Height="1" Fill="{DynamicResource Surface1}" Margin="0,12,0,12" />

                <!-- Shortcuts -->
                <TextBlock Text="Shortcuts" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6" />
                <CheckBox x:Name="DesktopCheck" Content="Create desktop shortcut" IsChecked="True" />
                <CheckBox x:Name="StartMenuCheck" Content="Create Start Menu shortcut" IsChecked="True" />
                <CheckBox x:Name="AutostartCheck" Content="Start with Windows" />

                <!-- Separator -->
                <Rectangle Height="1" Fill="{DynamicResource Surface1}" Margin="0,12,0,12" />

                <!-- Optional Tools -->
                <TextBlock Text="Optional Tools" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6" />
                <CheckBox x:Name="OptionalDepsCheck" Content="Install optional Python tools (requires Python in PATH)"
                          Checked="OptionalDepsCheck_Changed" Unchecked="OptionalDepsCheck_Changed" />
                <StackPanel x:Name="OptionalDepsPanel" Margin="20,6,0,0" Visibility="Collapsed">
                    <CheckBox x:Name="DepAutoEditor" Content="auto-editor (motion-based auto-editing)" IsChecked="True" />
                    <CheckBox x:Name="DepEdgeTts" Content="edge-tts (text-to-speech)" IsChecked="True" />
                    <CheckBox x:Name="DepMediapipe" Content="mediapipe (face tracking for reframe)" IsChecked="True" />
                </StackPanel>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{DynamicResource Surface1}" Margin="0,12,0,12" />

                <!-- AI Models -->
                <TextBlock Text="AI Models" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Subtext1}" Margin="0,0,0,6" />
                <CheckBox x:Name="WhisperCheck" Content="Download Whisper model for captions"
                          Checked="WhisperCheck_Changed" Unchecked="WhisperCheck_Changed" />
                <StackPanel x:Name="ModelPanel" Margin="20,6,0,0" Visibility="Collapsed">
                    <RadioButton x:Name="ModelTiny" Content="tiny (75 MB) — Fastest, lower accuracy" GroupName="Model" />
                    <RadioButton x:Name="ModelBase" Content="base (150 MB) — Good balance" GroupName="Model" />
                    <RadioButton x:Name="ModelSmall" Content="small (500 MB) — Better accuracy, slower" GroupName="Model" />
                    <RadioButton x:Name="ModelMedium" Content="medium (1.5 GB) — High accuracy, more RAM" GroupName="Model" />
                    <RadioButton x:Name="ModelTurbo" Content="turbo (1.6 GB) — Best speed/accuracy (recommended)"
                                 GroupName="Model" IsChecked="True" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Back"
                    Style="{StaticResource SecondaryButton}"
                    Click="Back_Click" Margin="0,0,10,0" />
            <Button Grid.Column="2" Content="Install"
                    Style="{StaticResource PrimaryButton}"
                    Click="Install_Click" />
        </Grid>
    </Grid>
</Page>
