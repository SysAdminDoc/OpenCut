<Page x:Class="OpenCut.Installer.Pages.ProgressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenCut.Installer.Controls"
      Background="Transparent">

    <Grid Margin="44,22,44,34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Installing OpenCut…" Style="{StaticResource SectionTitleText}" />
            <TextBlock x:Name="ProgressSummaryText"
                       Text="Setting up the local server, Premiere integration, and any extras you selected. First install can take a few minutes."
                       Style="{StaticResource BodyText}" Margin="0,8,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource SetupHeroBorder}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ProgressStateText" Text="Preparing setup…"
                               Foreground="{DynamicResource TextBrush}" FontSize="14.5"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StepLabel" Text="Gathering the install plan and preparing files."
                               Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1" Background="#20362b" BorderBrush="{DynamicResource Surface1}"
                        BorderThickness="1" CornerRadius="999" Padding="10,4" HorizontalAlignment="Right">
                    <TextBlock x:Name="ProgressPercentText" Text="0%"
                               Foreground="{DynamicResource Green}" FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <ProgressBar x:Name="ProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" />
            <Border x:Name="Shimmer" Height="10" CornerRadius="5"
                    HorizontalAlignment="Left" Width="96"
                    IsHitTestVisible="False" Opacity="0.32">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0" />
                        <GradientStop Color="#40FFFFFF" Offset="0.5" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource SetupCardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="18,16,18,12">
                    <TextBlock Text="Install Log" Foreground="{DynamicResource TextBrush}"
                               FontSize="14.5" FontWeight="SemiBold" />
                    <TextBlock Text="Live activity from setup appears here so you can see what changed and where the installer is spending time."
                               Style="{StaticResource CaptionText}" Margin="0,4,0,0" />
                </StackPanel>

                <controls:LogPanel x:Name="LogPanel" Grid.Row="1" Margin="18,0,18,18" />
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CloseBtn" Grid.Column="1" Content="Close Setup" Width="120"
                    Visibility="Collapsed" Click="CloseBtn_Click"
                    Style="{StaticResource SecondaryButton}" />
        </Grid>
    </Grid>
</Page>
