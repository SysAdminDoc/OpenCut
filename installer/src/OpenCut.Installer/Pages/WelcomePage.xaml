<Page x:Class="OpenCut.Installer.Pages.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="40,20,40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Center Content -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel.RenderTransform>
                <TranslateTransform />
            </StackPanel.RenderTransform>

            <!-- Logo -->
            <Image x:Name="Logo" Source="/Assets/logo.png" Width="96" Height="96"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center" Margin="0,0,0,20"
                   Opacity="0">
                <Image.RenderTransform>
                    <TranslateTransform />
                </Image.RenderTransform>
            </Image>

            <!-- Title -->
            <TextBlock Text="OpenCut" FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="{DynamicResource UIFont}"
                       HorizontalAlignment="Center" Margin="0,0,0,4" />
            <TextBlock Text="v1.3.0" FontSize="14"
                       Foreground="{DynamicResource Overlay1}"
                       FontFamily="{DynamicResource UIFont}"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="Video Editing Automation for Premiere Pro"
                       FontSize="13" Foreground="{DynamicResource Subtext0}"
                       FontFamily="{DynamicResource UIFont}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Uninstall link (only shown if already installed) -->
            <Button x:Name="UninstallLink" Grid.Column="0"
                    Content="Uninstall" Visibility="Collapsed"
                    Style="{StaticResource LinkButton}" Click="UninstallLink_Click" />

            <Button Grid.Column="2" Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Margin="0,0,10,0" />
            <Button Grid.Column="3" Content="Install OpenCut"
                    Style="{StaticResource PrimaryButton}"
                    Click="Next_Click" />
        </Grid>
    </Grid>
</Page>
