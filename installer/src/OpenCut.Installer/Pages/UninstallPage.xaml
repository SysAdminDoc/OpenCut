<Page x:Class="OpenCut.Installer.Pages.UninstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenCut.Installer.Controls"
      Background="Transparent">

    <Grid Margin="40,16,40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="HeaderText" Grid.Row="0" Text="Uninstall OpenCut" FontSize="20" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   FontFamily="{DynamicResource UIFont}" Margin="0,0,0,6" />

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="1"
                   Text="This will remove OpenCut and all its components from your system."
                   FontSize="13" Foreground="{DynamicResource Subtext0}"
                   FontFamily="{DynamicResource UIFont}" Margin="0,0,0,12"
                   TextWrapping="Wrap" />

        <!-- Progress Bar (hidden until uninstall starts) -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="6"
                     Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed" Margin="0,0,0,12" />

        <!-- Log Panel -->
        <controls:LogPanel x:Name="LogPanel" Grid.Row="3" Margin="0,0,0,12" />

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn" Grid.Column="1" Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Margin="0,0,10,0" />
            <Button x:Name="UninstallBtn" Grid.Column="2" Content="Uninstall"
                    Click="Uninstall_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Background" Value="{StaticResource Red}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Maroon}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Page>
