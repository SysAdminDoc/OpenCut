<Page x:Class="OpenCut.Installer.Pages.UninstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:OpenCut.Installer.Controls"
      Background="Transparent">

    <Grid Margin="44,24,44,34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="HeaderText" Text="Uninstall OpenCut" Style="{StaticResource SectionTitleText}" />
            <TextBlock x:Name="StatusText"
                       Text="This removes OpenCut, its components, and supporting shortcuts from this machine."
                       Style="{StaticResource BodyText}" Margin="0,8,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource DangerTintBrush}" BorderBrush="{DynamicResource Surface1}"
                BorderThickness="1" CornerRadius="12" Padding="14,12" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="OpenCut user data is preserved by default."
                           Style="{StaticResource CaptionText}" Foreground="{DynamicResource TextBrush}" />
                <CheckBox x:Name="RemoveUserDataCheckBox"
                          Content="Also remove settings, jobs, journals, indexes, plugins, models, and project/agent state"
                          AutomationProperties.Name="Remove OpenCut user data after backup"
                          AutomationProperties.HelpText="Unchecked by default. Creates and validates a backup outside the OpenCut data folder before removal."
                          Margin="0,10,0,0" />
                <TextBlock x:Name="UserDataPathText" Style="{StaticResource CaptionText}" Margin="24,4,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="10"
                     Minimum="0" Maximum="100" Value="0"
                     AutomationProperties.Name="Uninstall progress"
                     AutomationProperties.HelpText="Shows overall OpenCut removal progress from 0 to 100 percent."
                     Visibility="Collapsed" Margin="0,0,0,14" />

        <Border Grid.Row="3" Style="{StaticResource SetupCardBorder}" Padding="0" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="18,16,18,12">
                    <TextBlock Text="Uninstall Log" Foreground="{DynamicResource TextBrush}"
                               FontSize="14.5" FontWeight="SemiBold" />
                    <TextBlock Text="Removal activity and any cleanup issues will appear here."
                               Style="{StaticResource CaptionText}" Margin="0,4,0,0" />
                </StackPanel>

                <controls:LogPanel x:Name="LogPanel" Grid.Row="1" Margin="18,0,18,18"
                                   AutomationProperties.Name="Uninstall activity log" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn" Grid.Column="1" Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Margin="0,0,10,0" />
            <Button x:Name="UninstallBtn" Grid.Column="2" Content="Remove OpenCut"
                    AutomationProperties.HelpText="Removes the local app, integration files, and shortcuts from this machine."
                    Click="Uninstall_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Background" Value="{StaticResource Red}" />
                        <Setter Property="Foreground" Value="White" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Maroon}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Page>
